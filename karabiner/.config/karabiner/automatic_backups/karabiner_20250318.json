{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [


                        {
                        "description": "Caps Lock + 3 for Markdown Preview only in Sublime Text",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "3",
                                    "modifiers": {
                                        "mandatory": ["left_command", "left_control", "left_option", "left_shift"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "3",
                                        "modifiers": ["left_command", "left_control", "left_option", "left_shift"]
                                    }
                                ],
                                "conditions": [
                                    {
                                        "type": "frontmost_application_if",
                                        "bundle_identifiers": [
                                            "^com.sublimetext.3$"
                                        ]
                                    }
                                ]
                            }
                        ]
                    }


                    
                    {
                        "manipulators": [
                            {
                                "description": "Change caps_lock to command+control+option+shift.",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Fix § and ° next to 1 on Swedish ISO keyboard",
                        "manipulators": [
                            {
                                "from": { "key_code": "non_us_backslash" },
                                "to": [{ "key_code": "grave_accent_and_tilde" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "non_us_backslash",
                                    "modifiers": { "mandatory": ["shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "grave_accent_and_tilde",
                                        "modifiers": ["shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Fix < and > next to Z on Swedish ISO keyboard",
                        "manipulators": [
                            {
                                "from": { "key_code": "grave_accent_and_tilde" },
                                "to": [{ "key_code": "non_us_backslash" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "grave_accent_and_tilde",
                                    "modifiers": { "mandatory": ["shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "non_us_backslash",
                                        "modifiers": ["shift"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}